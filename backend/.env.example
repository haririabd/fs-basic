# ============================================
# UNIVERSAL CONFIGURATION (works everywhere)
# ============================================

# Django
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=

# Frontend URL (for email links, CORS, CSRF)
# Local: http://localhost:3000
# Railway: https://your-frontend.railway.app
# VPS: https://example.com
# Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Allowed hosts (comma-separated)
# Local: localhost,127.0.0.1
# Railway: *.railway.app
# VPS: example.com,www.example.com
# Vercel: your-app.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (comma-separated)
# Local: http://localhost:3000,http://localhost:5173
# Production: https://your-frontend.domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
# Local: (leave empty for SQLite)
# Remote: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Codespace (only needed in GitHub Codespace)
ON_CODESPACE=False

# Email settings
ZEPTOMAIL_API_TOKEN=''
EMAIL_HOST='smtp.zeptomail.com'
EMAIL_HOST_USER=''
EMAIL_HOST_PASSWORD=''
DEFAULT_FROM_EMAIL=''

# Superuser credentials (for local development only)
DJANGO_SUPERUSER_USERNAME=''
DJANGO_SUPERUSER_EMAIL=''
DJANGO_SUPERUSER_PASSWORD=''